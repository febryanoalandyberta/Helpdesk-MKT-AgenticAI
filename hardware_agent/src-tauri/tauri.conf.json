{
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devPath": "../src",
    "distDir": "../src",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "MKT Hardware Agent",
    "version": "1.0.8"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "dialog": {
        "all": true
      },
      "window": {
        "all": true
      },
      "shell": {
        "all": false,
        "execute": true,
        "open": true
      },
      "http": {
        "all": true,
        "request": true
      }
    },
    "bundle": {
      "active": true,
      "targets": ["nsis"],
      "identifier": "com.megakreasitech.hardwareagent",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.ico"
      ]
    },
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' http://10.20.0.193:8000 ws://10.20.0.193:8000 tauri: asset: blob: data:;"
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "MKT Hardware Agent Chat",
        "width": 400,
        "height": 600,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true
      }
    ],
    "systemTray": {
      "iconPath": "icons/icon.ico",
      "iconAsTemplate": true
    }
  }
}
