# =============================================
# HELPDESK MKT AGENTIC AI AUTOMATION
# Environment Configuration Template
# =============================================
# Copy this file to .env and fill in your values

# === APPLICATION ===
APP_NAME="Helpdesk MKT Agentic AI"
APP_ENV=development
APP_PORT=8000
APP_SECRET_KEY=your-super-secret-key-change-this-in-production
DEBUG=true

# === DATABASE (PostgreSQL) ===
DB_HOST=localhost
DB_PORT=5432
DB_NAME=helpdesk_mkt
DB_USER=mkt_user
DB_PASSWORD=mkt_password
DATABASE_URL=postgresql+asyncpg://mkt_user:mkt_password@localhost:5432/helpdesk_mkt

# === REDIS ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# === ZAMMAD ===
ZAMMAD_URL=https://your-zammad-instance.com
ZAMMAD_TOKEN=your-zammad-api-token
ZAMMAD_POLL_INTERVAL=30

# === TELEGRAM ===
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_DEFAULT_GROUP_ID=your-default-group-id

# === OPENAI (for CrewAI) ===
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o

# === JWT AUTH ===
JWT_SECRET=your-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# === CHROMADB (Vector DB) ===
CHROMA_HOST=localhost
CHROMA_PORT=8001

# === CORS ===
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# === AGENT SETTINGS ===
TIER0_CONFIDENCE_THRESHOLD=85
TIER1_ESCALATION_TIMEOUT=300
MAX_CONCURRENT_AGENTS=5
